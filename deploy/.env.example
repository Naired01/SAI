# SAI — Environment variables (example / dev defaults)
#
# Copia este archivo a deploy/.env y ajusta los valores antes de
# `docker compose up -d --build`. NO commitees el .env real.

# Runtime --------------------------------------------------------------------
SAI_ENV=development                            # development | production
SAI_BIND=:8080
SAI_LOG_LEVEL=info                             # debug | info | warn | error
SAI_TLS_MODE=reverse_proxy                     # reverse_proxy | direct

# URLs -----------------------------------------------------------------------
# URL pública bajo la que se sirve el panel (https://sai.tudominio.com)
# Usada para construir las URLs WSS de los agentes y los enlaces de descarga.
SAI_PUBLIC_URL=https://sai.tudominio.com

# Base de datos --------------------------------------------------------------
# Formato: postgres://USER:PASS@HOST:PORT/DBNAME?sslmode=...
SAI_DB_URL=postgres://sai:sai@postgres:5432/sai?sslmode=disable

# Secretos JWT (>= 32 caracteres; generar con `openssl rand -hex 32`) ---------
SAI_JWT_SECRET=cambia-esto-en-produccion-a-al-menos-32-chars
SAI_AGENT_JWT_SECRET=cambia-esto-tambien-32-chars-min

# Tokens de enrolamiento -----------------------------------------------------
SAI_AGENT_TOKEN_TTL=24h                        # duración por defecto de tokens nuevos

# Bundle de agente -----------------------------------------------------------
SAI_BUNDLE_DIR=/app/dist                       # ruta donde están los binarios base

# i18n ------------------------------------------------------------------------
SAI_DEFAULT_LANG=es                            # es | en

# Sesiones admin -------------------------------------------------------------
SAI_SESSION_TTL=8h

# Web UI (panel) -------------------------------------------------------------
SAI_WEB_DIST=/app/web

# Bootstrap admin (opcional) -------------------------------------------------
# Si los pones al arrancar el server por primera vez y la tabla users está
# vacía, se crea el admin automáticamente.
SAI_BOOTSTRAP_EMAIL=admin@sai.local
SAI_BOOTSTRAP_PASSWORD=CambiaEsto#2026

# Postgres (usado por docker-compose) ----------------------------------------
POSTGRES_USER=sai
POSTGRES_PASSWORD=sai
POSTGRES_DB=sai